#!/usr/bin/env bash
HERE="$(cd "$(dirname "$0")" && pwd)"
export PATH="$HERE/usr/bin:$PATH"
export LD_LIBRARY_PATH="$HERE/usr/lib:${LD_LIBRARY_PATH:-}"

CMD="${1:-}"
case "$CMD" in
    stack)  shift; exec "$HERE/usr/bin/aqstack" "$@" ;;
    lrgb)   shift; exec "$HERE/usr/bin/aqlrgb"  "$@" ;;
    script) shift; exec "$HERE/usr/bin/aqcli"   "$@" ;;
    *)
        echo "Aquila - astrophotography data processing toolkit"
        echo ""
        echo "Usage: aquila <command> [options]"
        echo ""
        echo "Commands:"
        echo "  stack    Stack and calibrate CCD frames (aqstack)"
        echo "  lrgb     Composite multi-filter colour images (aqlrgb)"
        echo "  script   Run an aqcli processing script (aqcli)"
        echo ""
        echo "Pass -h after a command for its own help."
        exit 1
        ;;
esac
